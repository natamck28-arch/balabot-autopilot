# ============================================================
#  SOCIAL AUTOPILOT — environment config
#  Copy to .env and fill in. Never commit .env.
# ============================================================

# --- Server ---
PORT=3000
PUBLIC_URL=https://your-domain.com          # public https URL of THIS server (for OAuth redirect + webhooks)
ADMIN_TOKEN=change-me-to-a-long-random-string # protects the /dashboard

# --- Meta / Facebook App (create at developers.facebook.com) ---
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0

# --- Instagram OAuth (Facebook Login) ---
# Redirect URI must be registered in the Meta app:  {PUBLIC_URL}/onboarding/callback
IG_OAUTH_SCOPES=instagram_basic,instagram_content_publish,pages_show_list,business_management,pages_read_engagement

# --- WhatsApp Cloud API ---
WA_PHONE_NUMBER_ID=            # from WhatsApp > API Setup
WA_ACCESS_TOKEN=               # permanent system-user token recommended
WA_VERIFY_TOKEN=pick-any-secret-string   # you also type this into the webhook config in Meta
WA_BUSINESS_NUMBER=            # e.g. +15550001111 (display only)

# --- AI provider (captions + conversation). Use ONE. ---
AI_PROVIDER=anthropic          # anthropic | openai | none
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-5

# --- Image enhancement provider (optional; see src/services/images.js) ---
IMAGE_PROVIDER=none            # none | replicate | your-service
REPLICATE_API_TOKEN=

# --- Billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=               # the monthly subscription price id
